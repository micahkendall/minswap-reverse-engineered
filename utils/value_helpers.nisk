@captures 1;
fn map_contains_data_key_template(_capture, map_entries, target_key) {
  zcom fn (walk_entries, remaining_entries) {
    !
      (chooseList(
        remaining_entries,
        #False,
        #
          {
            let [map_entry, remaining_entries_tail] =
              remaining_entries;
            let entry_key =
              fstPair(map_entry);
            or { target_key =d= entry_key, walk_entries(walk_entries, remaining_entries_tail) }
          }
      ))
  }(map_entries)
}

@captures 7;
fn resolve_route_input_amount(
  constr_tag_of, constr_fields_of, value_token_amount, route_input_amount_option,
  order_input_value, order_input_asset_policy_id, order_input_asset_name
) {
  let route_input_amount_option_tag =
    constr_tag_of(route_input_amount_option);
  !
  (
    if (0 =i= route_input_amount_option_tag) {
      #
      list_first_int(constr_fields_of(route_input_amount_option))
    } else {
      #
      {
        let route_input_amount_option_fields =
          constr_fields_of(route_input_amount_option);
        let excluded_route_input_amount =
          list_first_int(route_input_amount_option_fields);
        assert(0 <= excluded_route_input_amount);
        value_token_amount(
          order_input_value,
          order_input_asset_policy_id,
          order_input_asset_name
        ) - excluded_route_input_amount
      }
    }
  )
}

@captures 9;
fn route_terminal_value(
  value_add, order_input_value, order_batcher_fee, order_input_asset_policy_id,
  order_input_asset_name, route_input_amount, order_output_asset_policy_id, order_output_asset_name,
  computed_route_output_amount
) {
  value_add(value_add(value_add(order_input_value, 0x, 0x, 0 - order_batcher_fee), order_input_asset_policy_id,
  order_input_asset_name, 0 - route_input_amount), order_output_asset_policy_id, order_output_asset_name,
  computed_route_output_amount)
}

