            unBData(fstPair(value_entry));
          let value_entry_assets =
            unMapData(sndPair(value_entry));
          !
            (
              if (compare_bytes_order(policy_id, value_entry_policy_id) =d= data(constr 0 [])) {
                #
                  (mkCons(mkPairData(bData(policy_id), mapData(singleton_asset_entries)), remaining_value_entries))
              } else {
                #
                  !
                    (
                      if (policy_id =b= value_entry_policy_id) {
                        #
                          {
                            let updated_asset_map_option =
                              {
                                let updated_asset_entries =
                                  {
                                    let add_asset =
                                      add_asset_entry(constr_tag_of, compare_bytes_order, token_name, token_amount);
                                    add_asset(add_asset, value_entry_assets)
                                  };
                                nonempty_asset_map_option(updated_asset_entries)
                              };
                            prepend_policy_entry_when_option_some(policy_id, constr_fields_of, updated_asset_map_option, remaining_after_value_entry)(
                              constr_tag_of(updated_asset_map_option)
                            )
                          }
                      } else {
                        #
                          (mkCons(
                            mkPairData(bData(value_entry_policy_id), mapData(value_entry_assets)),
                            insert_policy_entry(insert_policy_entry, remaining_after_value_entry)
                          ))
                      }
                    )
              }
            )
        }
    ))
}

@captures 3;
fn make_add(constr_tag_of, constr_fields_of, compare_bytes_order, value_map, policy_id, token_name, token_amount) {
  !
    (
      if (token_amount =i= 0) {
        #value_map
      } else {
        #
          {
            let singleton_asset_entries =
              {
                let singleton_asset_entry =
                  mkCons(
                    mkPairData(bData(token_name), iData(token_amount)),
                    list<pair<data, data>>[]
                  );
                let checked_singleton_asset_order =
                  {
                    let assert_asset_order =
                      assert_sorted_asset_entries(constr_tag_of, compare_bytes_order);
                    assert_asset_order(assert_asset_order, singleton_asset_entry)
                  };
                singleton_asset_entry
              };
            let insert_policy =
              insert_value_policy(constr_tag_of, constr_fields_of, compare_bytes_order, policy_id, token_name, token_amount, singleton_asset_entries);
            insert_policy(insert_policy, value_map)
          }
      }
    )
}

@captures 2;
fn make_amount(constr_tag_of, constr_fields_of, value_map, policy_id, token_name) {
  let policy_lookup_option =
    {
      let find_policy_entry =
        find_policy_entry_template(policy_id);
      find_policy_entry(find_policy_entry, value_map)
    };
  let asset_lookup_option =
    {
      let policy_lookup_tag =
        constr_tag_of(policy_lookup_option);
      !
        (
          if (1 =i= policy_lookup_tag) {
            #data(constr 1 [])
          } else {
            #
              {
                let asset_map =
                  unMapData(constr_first_field(policy_lookup_option));
                let find_asset_entry =
                  find_asset_entry_template(token_name);
                find_asset_entry(find_asset_entry, asset_map)
              }
          }
        )
    };
  let asset_lookup_tag =
    constr_tag_of(asset_lookup_option);
  !
    (if (1 =i= asset_lookup_tag) { #0 } else { #list_first_int(constr_fields_of(asset_lookup_option)) })
}

@captures 1;
