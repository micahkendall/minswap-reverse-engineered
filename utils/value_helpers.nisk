@captures 7;
fn insert_value_policy(constr_tag_of, constr_fields_of, compare_bytes_order, policy_id, token_name, token_amount, singleton_asset_entries, insert_policy_entry,
  remaining_value_entries) {
  !
    (chooseList(
      remaining_value_entries,
      #mkCons(mkPairData(bData(policy_id), mapData(singleton_asset_entries)), list<pair<data, data>>[]),
      #
        {
          let [value_entry, remaining_after_value_entry] =
            remaining_value_entries;
