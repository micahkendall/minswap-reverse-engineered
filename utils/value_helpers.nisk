@captures 5;
fn factory_continuation_output_matches(constr_fields_of, own_spending_credential, remove_ada_policy, value_singleton, factory_policy_id, candidate_output) {
  let candidate_output_fields =
    constr_fields_of(candidate_output);
  let [candidate_output_address, candidate_output_after_address] =
    candidate_output_fields;
  let candidate_output_value =
    list_first_map(candidate_output_after_address);
  let candidate_output_address_fields =
    constr_fields_of(candidate_output_address);
  let candidate_output_credential =
    list_first(candidate_output_address_fields);
  and {
    own_spending_credential =d= candidate_output_credential,
    mapData(remove_ada_policy(candidate_output_value)) =d= mapData(value_singleton(factory_policy_id, 0x4d5346, 1))
  }
}

@captures 5;
fn pool_output_matches(constr_fields_of, constr_tag_of, value_amount, expected_pool_address, factory_policy_id, candidate_output) {
  let candidate_output_fields =
    constr_fields_of(candidate_output);
  let [candidate_output_address, candidate_output_after_address] =
    candidate_output_fields;
  let candidate_output_value =
    list_first_map(candidate_output_after_address);
  let candidate_output_address_fields =
    constr_fields_of(candidate_output_address);
  let candidate_credential =
    list_first(candidate_output_address_fields);
  let candidate_credential_tag =
    constr_tag_of(candidate_credential);
  and {
    1 =i= candidate_credential_tag,
    expected_pool_address =d= candidate_output_address,
    value_amount(candidate_output_value, factory_policy_id, 0x4d5350) =i= 1
  }
}

@captures 1;
fn integer_sqrt_iter(liquidity_product, iterate_sqrt, previous_guess, next_guess) {
  !
    (
      if (next_guess < previous_guess) {
        #
          (iterate_sqrt(
            iterate_sqrt,
            next_guess,
            (liquidity_product / next_guess + next_guess) / 2
          ))
      } else {
        #previous_guess
      }
    )
}
