branch "agent/minswap-reverse-engineer";
module_path "utils/value_helpers";

@captures 2;
fn asset_pair_lex_before_projected_pair(asset_fields_projector, right_asset_pair, left_asset_fields) {
  let [left_policy_id << unBData, left_asset_tail] =
    left_asset_fields;
  let left_token_name =
    list_first_bytes(left_asset_tail);
  let right_asset_fields =
    asset_fields_projector(right_asset_pair);
  let [right_policy_id << unBData, right_asset_tail] =
    right_asset_fields;
  let right_token_name =
    list_first_bytes(right_asset_tail);
  !if (left_policy_id =b= right_policy_id) { #(left_token_name <b< right_token_name) } else { #(left_policy_id <b< right_policy_id) }
}

@captures 4;
fn compute_lp_name(first_asset_policy_id, first_asset_token_name, second_asset_policy_id, second_asset_token_name) {
  let hash_bytes =
    sha3_hash_bytes;
  let concat_bytes =
    append_bytes;
  hash_bytes(
    concat_bytes(
      hash_bytes(concat_bytes(first_asset_policy_id, first_asset_token_name)),
      hash_bytes(concat_bytes(second_asset_policy_id, second_asset_token_name))
    )
  )
}

@captures 2;
fn validate_asset_pair_data(constr_tag_of, constr_fields_of, asset_pair) {
  let asset_pair_tag =
    constr_tag_of(asset_pair);
  assert(0 =i= asset_pair_tag);
  let asset_pair_fields =
    constr_fields_of(asset_pair);
  let [asset_policy_id << unBData, asset_pair_tail] =
    asset_pair_fields;
  let asset_token_name =
    list_first_bytes(asset_pair_tail);
  !
    (chooseList(tailList(asset_pair_tail), #(), #error))
}


@captures 1;
fn nonzero_amount_option(updated_asset_amount) {
  !
    (
      if (updated_asset_amount =i= 0) {
        #data(constr 1 [])
      } else {
        #
          (constrData(
            0,
            mkCons(iData(updated_asset_amount), list<data>[])
          ))
      }
    )
}

@captures 1;
fn nonempty_asset_map_option(updated_asset_entries) {
  !
    (
      if (!chooseList(updated_asset_entries, #True, #False)) {
        #data(constr 1 [])
      } else {
        #
          (constrData(
            0,
            mkCons(mapData(updated_asset_entries), list<data>[])
          ))
      }
    )
}

@captures 4;
fn add_asset_entry(constr_tag_of, compare_bytes_order, token_name, token_amount, insert_asset_entry, remaining_asset_entries) {
  !
    (chooseList(
      remaining_asset_entries,
      #mkCons(mkPairData(bData(token_name), iData(token_amount)), list<pair<data, data>>[]),
      #
        {
          let [asset_entry, remaining_after_asset_entry] =
            remaining_asset_entries;
          let asset_entry_name =
            unBData(fstPair(asset_entry));
          let asset_entry_amount =
            unIData(sndPair(asset_entry));
          !
            (
              if (compare_bytes_order(token_name, asset_entry_name) =d= data(constr 0 [])) {
                #
                  (mkCons(
                    mkPairData(bData(token_name), iData(token_amount)),
                    remaining_asset_entries
                  ))
              } else {
                #
                  !
                    (
                      if (token_name =b= asset_entry_name) {
                        #
                          {
                            let updated_asset_amount_option =
                              {
                                let updated_asset_amount = asset_entry_amount + token_amount;
                                nonzero_amount_option(updated_asset_amount)
                              };
                            let updated_asset_amount_tag =
                              constr_tag_of(updated_asset_amount_option);
                            !
                              (
                                if (0 =i= updated_asset_amount_tag) {
                                  #
                                    (mkCons(
                                      mkPairData(bData(token_name), constr_first_field(updated_asset_amount_option)),
                                      remaining_after_asset_entry
                                    ))
                                } else {
                                  #remaining_after_asset_entry
                                }
                              )
                          }
                      } else {
                        #
                          (mkCons(
                            mkPairData(bData(asset_entry_name), iData(asset_entry_amount)),
                            insert_asset_entry(insert_asset_entry, remaining_after_asset_entry)
                          ))
                      }
                    )
              }
            )
        }
    ))
}

@captures 2;
fn assert_sorted_asset_entries(constr_tag_of, compare_bytes_order, check_sorted_assets, remaining_asset_entries) {
  !
    (chooseList(
      remaining_asset_entries,
      #(),
      #
        {
          let after_first_asset_entry =
            tailList(remaining_asset_entries);
          !
            (chooseList(
              after_first_asset_entry,
              #(),
              #
                {
                  let first_asset_entry =
                    list_first(remaining_asset_entries);
                  let [second_asset_entry, after_second_asset_entry] =
                    after_first_asset_entry;
                  let first_asset_name =
                    unBData(fstPair(first_asset_entry));
                  let second_asset_name =
                    unBData(fstPair(second_asset_entry));
                  let asset_order =
                    compare_bytes_order(first_asset_name, second_asset_name);
                  let asset_order_tag =
                    constr_tag_of(asset_order);
                  assert(0 =i= asset_order_tag);
                  check_sorted_assets(check_sorted_assets, mkCons(second_asset_entry, after_second_asset_entry))
                }
            ))
        }
    ))
}

