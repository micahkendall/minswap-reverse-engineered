branch "agent/minswap-reverse-engineer";
module_path "utils/core_helpers";

@captures 1;
fn constr_tag(constructor_data) {
  fstPair(unConstrData(constructor_data))
}

@captures 1;
fn constr_fields(constructor_data) {
  sndPair(unConstrData(constructor_data))
}

@captures 1;
fn constr_first_field(constructor_data) {
  headList(constr_fields(constructor_data))
}

@captures 1;
fn constr_second_field(constructor_data) {
  headList(tailList(constr_fields(constructor_data)))
}

@captures 2;
fn inline_output_datum_data_template(constr_tag_of, constr_fields_of, output_datum) {
  let output_datum_tag =
    constr_tag_of(output_datum);
  assert(2 =i= output_datum_tag);
  headList(constr_fields_of(output_datum))
}

@captures 2;
fn assert_choice_bytes_data_template(constr_tag_of, constr_fields_of, choice_data) {
  let choice_tag =
    constr_tag_of(choice_data);
  !
    (
      if (0 =i= choice_tag) {
        #
          {
            let choice_fields =
              constr_fields_of(choice_data);
            let choice_bytes =
              list_first_bytes(choice_fields);
            !
              (chooseList(tailList(choice_fields), #(), #error))
          }
      } else {
        #
          !
            (
              if (1 =i= choice_tag) {
                #
                  {
                    let choice_fields =
                      constr_fields_of(choice_data);
                    let choice_bytes =
                      list_first_bytes(choice_fields);
                    !
                      (chooseList(tailList(choice_fields), #(), #error))
                  }
              } else {
                #
                  {
                    assert(2 =i= choice_tag);
                    let choice_fields =
                      constr_fields_of(choice_data);
                    let choice_bytes =
                      list_first_bytes(choice_fields);
                    !
                      (chooseList(tailList(choice_fields), #(), #error))
                  }
              }
            )
      }
    )
}

