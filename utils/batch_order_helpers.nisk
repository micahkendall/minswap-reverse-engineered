                    outputs_remaining, pool_snapshot_before_step, pool_asset_a,
                    pool_asset_b, base_fee_a_numerator, base_fee_b_numerator,
                    fee_sharing_option, order_input_value, order_batcher_fee,
                    refund_receiver_asset_data, refund_receiver_datum_choice_data,
                    success_receiver_asset_data, success_receiver_datum_choice_data
                  )
                } else {
                  #apply_pool_update_step(
                    constr_fields_of, constr_tag_of, list_first_constr_tag,
                    resolve_output_datum_data, assert_order_datum_shape,
                    matches_output_address_datum, value_add, value_token_amount,
                    constant_product_swap_out, scaled_amount_from_option,
                    proportional_amount_pair, adjust_value_for_pair_delta,
                    matches_output_address_value_datum, subtract_ada_amount,
                    compute_quadratic_swap_delta, compute_quadratic_liquidity_pair,
                    scaled_amount_with_denominator, is_ada_asset, datum_map,
                    pool_asset_a, pool_asset_b, pool_lp_asset,
                    base_fee_a_numerator, base_fee_b_numerator, fee_sharing_option,
                    order_step_data, outputs_remaining, order_input_value,
                    order_input_address, order_canceller_data, refund_receiver_asset_data,
                    refund_receiver_datum_choice_data, success_receiver_asset_data,
                    success_receiver_datum_choice_data, order_lp_asset_data,
                    max_order_batcher_fee, order_expiry_setting_data, order_batcher_fee,
                    pool_snapshot_before_step, pool_snapshot_from_values, order_step_tag
                  )
                }
              )
            }
          )
        }
      )
    }
  )
}

@captures 28;
fn apply_steps_template(constr_fields_of, constr_tag_of, list_first_constr_tag, data_pair_from_list, resolve_output_datum_data,
  assert_order_datum_shape, matches_output_address_datum, matches_output_address_value_datum, value_add, value_token_amount, constant_product_swap_out,
  scaled_amount_from_option, proportional_amount_pair, adjust_value_for_pair_delta, subtract_ada_amount, compute_quadratic_swap_delta,
  compute_quadratic_liquidity_pair, scaled_amount_with_denominator, apply_swap_step, is_ada_asset, datum_map, current_time_approximation, pool_asset_a,
  pool_asset_b, pool_lp_asset, base_fee_a_numerator, base_fee_b_numerator, fee_sharing_option, apply_steps, order_inputs_remaining, outputs_remaining,
  order_fees_remaining, pool_snapshot_before_step) {
  let [current_order_input, order_inputs_after_current] =
    order_inputs_remaining;
  let [order_batcher_fee << unIData, order_fees_after_current] =
    order_fees_remaining;
  let order_input_fields =
    constr_fields_of(current_order_input);
  let after_order_input_ref =
    tailList(order_input_fields);
  let order_input_resolved_output =
    list_first(after_order_input_ref);
  let order_input_output_fields =
    constr_fields_of(order_input_resolved_output);
  let [order_input_address, after_order_input_address] =
    order_input_output_fields;
  let [order_input_value << unMapData, after_order_input_value] =
    after_order_input_address;
  let order_input_datum_reference =
    list_first(after_order_input_value);
  let order_datum_data =
    resolve_output_datum_data(datum_map, order_input_datum_reference);
  let order_datum_shape_checked =
    assert_order_datum_shape(order_datum_data);
  let order_datum_fields =
    constr_fields_of(order_datum_data);
  let [order_canceller_data, after_order_canceller] =
    order_datum_fields;
  let [refund_receiver_asset_data, after_refund_receiver_asset] =
    after_order_canceller;
  let [refund_receiver_datum_choice_data, after_refund_receiver_datum_choice] =
    after_refund_receiver_asset;
  let [success_receiver_asset_data, after_success_receiver_asset] =
    after_refund_receiver_datum_choice;
  let [success_receiver_datum_choice_data, after_success_receiver_datum_choice] =
    after_success_receiver_asset;
  let [order_lp_asset_data, after_order_lp_asset] =
    after_success_receiver_datum_choice;
  let [order_step_data, after_order_step] =
    after_order_lp_asset;
  let [max_order_batcher_fee << unIData, after_max_order_batcher_fee] =
    after_order_step;
  let order_expiry_setting_data =
    list_first(after_max_order_batcher_fee);
  assert(
    (
      and {
        0 < max_order_batcher_fee,
        0 < order_batcher_fee,
        order_batcher_fee <= max_order_batcher_fee,
        pool_lp_asset =d= order_lp_asset_data,
        {
          let expiry_setting_tag =
            constr_tag_of(order_expiry_setting_data);
          or {
            1 =i= expiry_setting_tag,
            {
              let expiry_setting_fields =
                constr_fields_of(order_expiry_setting_data);
              (
                current_time_approximation <=
                  unIData(fstPair({
                    let expiry_time_pair_fields =
                      list_first_list(expiry_setting_fields);
                    data_pair_from_list(expiry_time_pair_fields)
                  }))
              )
            },
          }
        },
      }
    )
  );
  let step_state_and_outputs_pair =
    apply_current_order_step(
      constr_fields_of, constr_tag_of, list_first_constr_tag, resolve_output_datum_data,
      assert_order_datum_shape, matches_output_address_datum, value_add, value_token_amount,
      constant_product_swap_out, scaled_amount_from_option, proportional_amount_pair,
      adjust_value_for_pair_delta, matches_output_address_value_datum, subtract_ada_amount,
      compute_quadratic_swap_delta, compute_quadratic_liquidity_pair,
      scaled_amount_with_denominator, apply_swap_step, is_ada_asset, datum_map,
      pool_asset_a, pool_asset_b, pool_lp_asset, base_fee_a_numerator,
      base_fee_b_numerator, fee_sharing_option, order_step_data, outputs_remaining,
      order_input_value, order_input_address, order_canceller_data,
      refund_receiver_asset_data, refund_receiver_datum_choice_data,
      success_receiver_asset_data, success_receiver_datum_choice_data,
      order_lp_asset_data, max_order_batcher_fee, order_expiry_setting_data,
      order_batcher_fee, pool_snapshot_before_step, pool_snapshot_from_values
    );
  let next_pool_snapshot =
    unListData(fstPair(step_state_and_outputs_pair));
  let outputs_after_current_step =
    unListData(sndPair(step_state_and_outputs_pair));
  !(chooseList(
    order_inputs_after_current,
    #next_pool_snapshot,
    #apply_steps(
      apply_steps,
      order_inputs_after_current,
      outputs_after_current_step,
      order_fees_after_current,
      next_pool_snapshot
    )
  ))
}

@captures 4;
fn build_step_datum_template(build_pool_state_datum, stake_credential_data, constr_fields_of, pool_policy_id, pool_input_info_data,
  pool_output_data, volatility_fee_data) {
  build_pool_state_datum(stake_credential_data, list_second(constr_fields_of(pool_input_info_data)),
    pool_output_data, pool_policy_id, True, volatility_fee_data)
}

@captures 1;
fn map_step_datums_template(build_step_datum, map_step_datums, pool_input_infos, pool_outputs, route_volatility_fees) {
  let [current_pool_input_info, remaining_pool_input_infos] =
    pool_input_infos;
  let [current_pool_output, remaining_pool_outputs] =
    pool_outputs;
  let [pool_volatility_fee, remaining_route_volatility_fees] =
    route_volatility_fees;
  !
  (
    if (listData(remaining_pool_input_infos) =d= data([])) {
      #
      {
        assert(
        (
        and {
          data([]) =d= listData(remaining_pool_outputs),
          data([]) =d= listData(remaining_route_volatility_fees),
        }
        )
        );
        mkCons(build_step_datum(current_pool_input_info, current_pool_output, pool_volatility_fee), list<data>[])
      }
    } else {
      #
      (mkCons(build_step_datum(current_pool_input_info, current_pool_output,
      pool_volatility_fee), map_step_datums(map_step_datums, remaining_pool_input_infos,
      remaining_pool_outputs, remaining_route_volatility_fees)))
    }
  )
}


@captures 4;
fn validate_step_outputs_template(constr_fields_of, list_first_constr_tag, constant_product_swap_out, scaled_amount_from_option,
  validate_step_outputs, swap_input_amount, batch_step_datums, route_pool_steps) {
  let [batch_step_datum, remaining_batch_step_datums] =
    batch_step_datums;
  let [route_pool_step, remaining_route_pool_steps] =
    route_pool_steps;
  let step_output_amount =
    {
    let batch_step_fields =
      constr_fields_of(batch_step_datum);
    let after_step_asset_a =
      tailList(batch_step_fields);
    let after_step_asset_b =
      tailList(after_step_asset_a);
    let [step_lp_asset, after_step_lp_asset] =
      after_step_asset_b;
    let [base_fee_a_numerator << unIData, after_base_fee_a] =
      after_step_lp_asset;
    let [base_fee_b_numerator << unIData, after_base_fee_b] =
      after_base_fee_a;
    let [fee_sharing_option, after_fee_sharing] =
      after_base_fee_b;
    let [input_pool_snapshot << unListData, after_input_pool_snapshot] =
      after_fee_sharing;
    let output_pool_snapshot =
      list_first_list(after_input_pool_snapshot);
    let [input_reserve_a << unIData, after_input_reserve_a] =
      input_pool_snapshot;
    let [input_reserve_b << unIData, after_input_reserve_b] =
      after_input_reserve_a;
    let [input_value_a << unIData, after_input_value_a] =
      after_input_reserve_b;
    let input_value_b =
      list_first_int(after_input_value_a);
    let [output_reserve_a << unIData, after_output_reserve_a] =
      output_pool_snapshot;
    let [output_reserve_b << unIData, after_output_reserve_b] =
      after_output_reserve_a;
    let [output_value_a << unIData, after_output_value_a] =
      after_output_reserve_b;
    let output_value_b =
      list_first_int(after_output_value_a);
    let route_pool_step_fields =
      constr_fields_of(route_pool_step);
    let [route_pool_lp_asset, route_pool_step_tail] =
      route_pool_step_fields;
    let swap_asset_a_to_b =
      1 =i= list_first_constr_tag(route_pool_step_tail);
    assert(step_lp_asset =d= route_pool_lp_asset);
    let swap_context =
      !
    (
      if (swap_asset_a_to_b) {
        #
        (mkCons(
        iData(input_reserve_a),
        mkCons(iData(input_reserve_b), mkCons(iData(base_fee_a_numerator), list<data>[]))
        ))
      } else {
        #
        (mkCons(
        iData(input_reserve_b),
        mkCons(iData(input_reserve_a), mkCons(iData(base_fee_b_numerator), list<data>[]))
        ))
      }
    );
    let [swap_input_reserve << unIData, after_swap_input_reserve] =
      swap_context;
    let [swap_output_reserve << unIData, after_swap_output_reserve] =
      after_swap_input_reserve;
    let swap_fee_numerator =
      list_first_int(after_swap_output_reserve);
    assert(0 < swap_input_amount);
    let swap_output_amount =
      constant_product_swap_out(swap_input_reserve, swap_output_reserve, swap_input_amount, swap_fee_numerator);
    let fee_sharing_input_amount =
      scaled_amount_from_option(swap_input_amount, swap_fee_numerator, fee_sharing_option);
    assert(0 < swap_output_amount);
    assert(
      !if (swap_asset_a_to_b) { #(and { input_reserve_a + swap_input_amount - fee_sharing_input_amount =i=
            output_reserve_a, input_reserve_b - swap_output_amount =i= output_reserve_b, input_value_a +
          swap_input_amount =i= output_value_a, input_value_b - swap_output_amount =i= output_value_b }) } else {
        #(and { input_reserve_a - swap_output_amount =i= output_reserve_a, input_reserve_b + swap_input_amount -
          fee_sharing_input_amount =i= output_reserve_b, input_value_a - swap_output_amount =i= output_value_a,
          input_value_b + swap_input_amount =i= output_value_b }) }
    );
    swap_output_amount
  };
  !
  (chooseList(remaining_batch_step_datums, #step_output_amount, #validate_step_outputs(
    validate_step_outputs, step_output_amount, remaining_batch_step_datums,
    remaining_route_pool_steps)))
}
