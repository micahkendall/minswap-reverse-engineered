@captures 7;
fn assert_order_swap_multi_step_shape(constr_fields_of, assert_each_list_item, constr_tag_of, list_first_constr_tag, validate_asset_pair,
  assert_tagged_single_int_bound, order_step_data) {
  let swap_multi_routing_fields =
    constr_fields_of(order_step_data);
  let [swap_routings << unListData, swap_multi_after_routings] =
    swap_multi_routing_fields;
  let [swap_multi_amount_option_data, swap_multi_after_amount_option] =
    swap_multi_after_routings;
  let swap_multi_minimum_receive =
    list_first_int(swap_multi_after_amount_option);
  !
    (chooseList(
      tailList(swap_multi_after_amount_option),
      # {
        let swap_routings_checked =
          assert_each_list_item(
            swap_routings,
            fn (routing_data) {
              let routing_tag =
                constr_tag_of(routing_data);
              assert(
                (
                  0
                  =i=
                  routing_tag
                )
              );
              let routing_fields =
                constr_fields_of(routing_data);
              let [routing_lp_asset_data, routing_after_lp_asset] =
                routing_fields;
              let routing_a_to_b =
                (
                  1
                  =i=
                  list_first_constr_tag(routing_after_lp_asset)
                );
              !
                (chooseList(
                  tailList(routing_after_lp_asset),
                  # {
                    let routing_lp_asset_checked =
                      validate_asset_pair(routing_lp_asset_data);
                    ()
                  },
                  #error
                ))
            }
          );
        let swap_multi_amount_option_checked =
          assert_tagged_single_int_bound(swap_multi_amount_option_data);
        ()
      },
      #error
    ))
}

