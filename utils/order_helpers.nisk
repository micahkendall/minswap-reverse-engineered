@captures 3;
fn expected_cancel_refund_datum_choice(constr_tag_of, constr_fields_of, output_datum_choice_data) {
  let credential_tag =
    constr_tag_of(output_datum_choice_data);
  !
    (
      if (0 =i= credential_tag) {
        #data(constr 0 [])
      } else {
        #
          !
            (
              if (1 =i= credential_tag) {
                #
                  (constrData(
                    1,
                    mkCons(
                      list_first(constr_fields_of(output_datum_choice_data)),
                      list<data>[]
                    )
                  ))
              } else {
                #
                  (constrData(
                    2,
                    mkCons(
                      bData(
                        blake2b_256(
                          serialiseData(list_first(constr_fields_of(output_datum_choice_data)))
                        )
                      ),
                      list<data>[]
                    )
                  ))
              }
            )
      }
    )
}

@captures 14;
fn validate_cancel_output_value(
  constr_tag_of,
  valid_from_time,
  expected_refund_address,
  actual_output_address,
  ada_amount_of,
  spent_order_value,
  continuing_output_value,
  remove_ada_policy,
  expected_refund_datum_choice,
  constr_fields_of,
  output_datum_choice_data,
  remaining_spent_order_inputs,
  continue_cancel_outputs,
  remaining_continuing_outputs,
  expiry_setting_data
) {
  assert(0 =i= constr_tag_of(expiry_setting_data));
  let expiry_setting_fields =
    constr_fields_of(expiry_setting_data);
  let expiry_value_pair =
    {
      let expiry_value_pair_fields =
        list_first_list(expiry_setting_fields);
      data_pair_from_list(expiry_value_pair_fields)
    };
  let expiry_value_pair_index =
    unIData(fstPair(expiry_value_pair));
  let expiry_value_pair_amount =
    unIData(sndPair(expiry_value_pair));
  assert(
    (
      and {
        expiry_value_pair_index < valid_from_time,
        expected_refund_address =d= actual_output_address,
        ada_amount_of(spent_order_value) - expiry_value_pair_amount <= ada_amount_of(continuing_output_value),
        mapData(remove_ada_policy(continuing_output_value)) =d= mapData(remove_ada_policy(spent_order_value)),
        (
          expected_refund_datum_choice
          =d=
          expected_cancel_refund_datum_choice(constr_tag_of, constr_fields_of, output_datum_choice_data)
        ),
      }
    )
  );
  or {
    listData(remaining_spent_order_inputs) =d= data([]),
    continue_cancel_outputs(
      continue_cancel_outputs,
      remaining_spent_order_inputs,
      remaining_continuing_outputs
    )
  }
}

@captures 2;
fn cancel_value_ada_amount_template(constr_tag_of, constr_fields_of, value_map) {
  let ada_policy_option =
    {
      fn find_ada_policy_entry(find_ada_policy_entry, remaining_policies) {
        !
          (chooseList(
            remaining_policies,
            #data(constr 1 []),
            # {
              let [policy_entry, remaining_after_policy] =
                remaining_policies;
              let policy_id =
                unBData(fstPair(policy_entry));
              let policy_assets =
                unMapData(sndPair(policy_entry));
              !
                (
                  if (0x =b= policy_id) {
                    #
                      (constrData(0, mkCons(mapData(policy_assets), list<data>[])))
                  } else {
                    #
                      (find_ada_policy_entry(find_ada_policy_entry, remaining_after_policy))
                  }
                )
            }
          ))
      }
      find_ada_policy_entry(find_ada_policy_entry, value_map)
    };
  let ada_asset_option =
    {
      let ada_policy_option_tag =
        constr_tag_of(ada_policy_option);
      !
        (
          if (1 =i= ada_policy_option_tag) {
            #data(constr 1 [])
          } else {
            # {
              let ada_policy_assets =
                list_first_map(constr_fields_of(ada_policy_option));
              fn find_ada_asset_entry(find_ada_asset_entry, remaining_assets) {
                !
                  (chooseList(
                    remaining_assets,
                    #data(constr 1 []),
                    # {
                      let [asset_entry, remaining_after_asset] =
                        remaining_assets;
                      let asset_name =
                        unBData(fstPair(asset_entry));
                      let asset_amount =
                        unIData(sndPair(asset_entry));
                      !
                        (
                          if (0x =b= asset_name) {
                            #
                              (constrData(0, mkCons(iData(asset_amount), list<data>[])))
                          } else {
                            #
                              (find_ada_asset_entry(find_ada_asset_entry, remaining_after_asset))
                          }
                        )
                    }
                  ))
              }
              find_ada_asset_entry(find_ada_asset_entry, ada_policy_assets)
            }
          }
        )
    };
  let ada_asset_option_tag =
    constr_tag_of(ada_asset_option);
  !
    (if (1 =i= ada_asset_option_tag) { #0 } else { #list_first_int(constr_fields_of(ada_asset_option)) })
}

@captures 1;
fn cancel_remove_ada_policy_template(_capture, value_map) {
  zcom fn (remove_ada_entries, remaining_policies) {
    !
      (chooseList(
        remaining_policies,
        #list<pair<data, data>>[],
        # {
          let [policy_entry, remaining_after_policy] =
            remaining_policies;
          let policy_id =
            unBData(fstPair(policy_entry));
          let policy_assets =
            unMapData(sndPair(policy_entry));
          !
            (
              if (0x =b= policy_id) {
                #remaining_after_policy
              } else {
                #
                  (mkCons(
                    mkPairData(bData(policy_id), mapData(policy_assets)),
                    remove_ada_entries(remove_ada_entries, remaining_after_policy)
                  ))
              }
            )
        }
      ))
  }(value_map)
}

@captures 2;
fn filter_credential_inputs_template(constr_fields_of, constr_tag_of, filter_script_credential_inputs, remaining_inputs) {
  !
    (chooseList(
      remaining_inputs,
      #list<data>[],
      # {
        let [input_data, remaining_after_input] =
          remaining_inputs;
        !
          (
            if (
              {
                let input_fields =
                  constr_fields_of(input_data);
                let input_after_output_ref =
                  tailList(input_fields);
                let input_output_data =
                  list_first(input_after_output_ref);
                let output_fields =
                  constr_fields_of(input_output_data);
                let output_address_data =
                  list_first(output_fields);
                let address_fields =
                  constr_fields_of(output_address_data);
                let payment_credential_data =
                  list_first(address_fields);
                let payment_credential_tag =
                  constr_tag_of(payment_credential_data);
                and { 1 =i= payment_credential_tag, True }
              }
            ) {
              #
                (mkCons(input_data, filter_script_credential_inputs(filter_script_credential_inputs, remaining_after_input)))
            } else {
              #
                (filter_script_credential_inputs(filter_script_credential_inputs, remaining_after_input))
            }
          )
      }
    ))
}

@captures 4;
fn resolve_cancel_order_datum(constr_tag_of, constr_fields_of, tx_datums, output_datum_choice) {
  let output_datum_tag =
    constr_tag_of(output_datum_choice);
  !
    (
      if (2 =i= output_datum_tag) {
        #
          list_first(constr_fields_of(output_datum_choice))
      } else {
        # {
          assert(1 =i= output_datum_tag);
          let output_datum_hash =
            list_first_bytes(constr_fields_of(output_datum_choice));
          fn lookup_datum_by_hash(lookup_datum_by_hash, remaining_datums) {
            !
              (chooseList(
                remaining_datums,
                #error,
                # {
                  let [datum_entry, remaining_datums_after_entry] =
                    remaining_datums;
                  let datum_entry_hash =
                    unBData(fstPair(datum_entry));
                  let datum_entry_value =
                    sndPair(datum_entry);
                  !
                    (
                      if (output_datum_hash =b= datum_entry_hash) {
                        #datum_entry_value
                      } else {
                        #lookup_datum_by_hash(
                          lookup_datum_by_hash,
                          remaining_datums_after_entry
                        )
                      }
                    )
                }
              ))
          }
          lookup_datum_by_hash(lookup_datum_by_hash, tx_datums)
        }
      }
    )
}

@captures 10;
fn assert_cancel_order_datum_shape(
  constr_tag_of,
  constr_fields_of,
  list_first_constr_tag,
  assert_tagged_single_int_bound,
  assert_tagged_single_int_data,
  assert_asset_pair_data,
  assert_address_data,
  assert_output_datum_choice_data,
  data_pair_from_list,
  order_datum_data
) {
  let order_datum_tag =
    constr_tag_of(order_datum_data);
  assert(0 =i= order_datum_tag);
  let order_datum_fields =
    constr_fields_of(order_datum_data);
  let [order_canceller_data, after_order_canceller] =
    order_datum_fields;
  let [refund_receiver_address_data, after_refund_receiver_address] =
    after_order_canceller;
  let [refund_receiver_datum_choice_data, after_refund_receiver_datum_choice] =
    after_refund_receiver_address;
  let [success_receiver_address_data, after_success_receiver_address] =
    after_refund_receiver_datum_choice;
  let [success_receiver_datum_choice_data, after_success_receiver_datum_choice] =
    after_success_receiver_address;
  let [order_lp_asset_data, after_order_lp_asset] =
    after_success_receiver_datum_choice;
  let [order_step_data, after_order_step] =
    after_order_lp_asset;
  let [max_order_batcher_fee << unIData, after_max_order_batcher_fee] =
    after_order_step;
  let order_expiry_setting_data =
    list_first(after_max_order_batcher_fee);
  !
    (chooseList(
      tailList(after_max_order_batcher_fee),
      # {
        let canceller_shape_checked =
          assert_canceller_shape_template(constr_tag_of, constr_fields_of, order_canceller_data);
        let refund_receiver_checked =
          assert_address_data(refund_receiver_address_data);
        let refund_receiver_datum_checked =
          assert_output_datum_choice_data(refund_receiver_datum_choice_data);
        let success_receiver_checked =
          assert_address_data(success_receiver_address_data);
        let success_receiver_datum_checked =
          assert_output_datum_choice_data(success_receiver_datum_choice_data);
        let lp_asset_checked =
          assert_asset_pair_data(order_lp_asset_data);
        let order_step_shape_checked =
          assert_cancel_order_step_shape_template(
            constr_tag_of,
            constr_fields_of,
            list_first_constr_tag,
            assert_tagged_single_int_bound,
            assert_tagged_single_int_data,
            assert_asset_pair_data,
            order_step_data
          );
        let expiry_setting_checked =
          assert_expiry_setting_shape_template(constr_tag_of, constr_fields_of, data_pair_from_list, order_expiry_setting_data);
        ()
      },
      #error
    ))
}

@captures 14;
fn validate_cancel_output_pairs_template(
  constr_fields_of,
  constr_tag_of,
  tx_datums,
  assert_address_data,
  assert_output_datum_choice_data,
  assert_asset_pair_data,
  list_first_constr_tag,
  assert_tagged_single_int_bound,
  assert_tagged_single_int_data,
  data_pair_from_list,
  start_valid_time_range,
  value_ada_amount,
  remove_ada_policy,
  validate_cancel_output_value,
  validate_cancel_output_pairs,
  spent_outputs,
  continuing_outputs
) {
  let [spent_order_input_data, remaining_spent_order_inputs] =
    spent_outputs;
  let [continuing_cancel_output_data, remaining_continuing_outputs] =
    continuing_outputs;
  let spent_order_input_fields =
    constr_fields_of(spent_order_input_data);
  let spent_order_input_after_ref =
    tailList(spent_order_input_fields);
  let spent_order_output_data =
    list_first(spent_order_input_after_ref);
  let spent_order_output_fields =
    constr_fields_of(spent_order_output_data);
  let spent_order_output_after_address =
    tailList(spent_order_output_fields);
  let [spent_order_value << unMapData, spent_order_output_after_value] =
    spent_order_output_after_address;
  let spent_order_output_datum_choice =
    list_first(spent_order_output_after_value);
  let continuing_output_fields =
    constr_fields_of(continuing_cancel_output_data);
  let [continuing_output_address_data, continuing_output_after_address] =
    continuing_output_fields;
  let [continuing_output_value << unMapData, continuing_output_after_value] =
    continuing_output_after_address;
  let continuing_output_datum_choice =
    list_first(continuing_output_after_value);
  let order_datum_data =
    resolve_cancel_order_datum(constr_tag_of, constr_fields_of, tx_datums, spent_order_output_datum_choice);
  let order_datum_shape_checked =
    assert_cancel_order_datum_shape(
      constr_tag_of,
      constr_fields_of,
      list_first_constr_tag,
      assert_tagged_single_int_bound,
      assert_tagged_single_int_data,
      assert_asset_pair_data,
      assert_address_data,
      assert_output_datum_choice_data,
      data_pair_from_list,
      order_datum_data
    );
  let cancel_datum_fields =
    constr_fields_of(order_datum_data);
  let cancel_after_order_canceller =
    tailList(cancel_datum_fields);
  let [cancel_refund_receiver_address_data, cancel_after_refund_receiver_address] =
    cancel_after_order_canceller;
  let [cancel_refund_receiver_datum_choice_data, cancel_after_refund_receiver_datum_choice] =
    cancel_after_refund_receiver_address;
  let cancel_after_success_receiver_address =
    tailList(cancel_after_refund_receiver_datum_choice);
  let cancel_after_success_receiver_datum_choice =
    tailList(cancel_after_success_receiver_address);
  let cancel_after_order_lp_asset =
    tailList(cancel_after_success_receiver_datum_choice);
  let cancel_after_order_step =
    tailList(cancel_after_order_lp_asset);
  let cancel_after_max_order_batcher_fee =
    tailList(cancel_after_order_step);
  validate_cancel_output_value(
    constr_tag_of,
    start_valid_time_range,
    cancel_refund_receiver_address_data,
    continuing_output_address_data,
    value_ada_amount,
    spent_order_value,
    continuing_output_value,
    remove_ada_policy,
    cancel_refund_receiver_datum_choice_data,
    constr_fields_of,
    continuing_output_datum_choice,
    remaining_spent_order_inputs,
    validate_cancel_output_pairs,
    remaining_continuing_outputs
  )(
    list_first(cancel_after_max_order_batcher_fee)
  )
}

@captures 5;
fn expiry_allows_batch(constr_tag_of, constr_fields_of, data_pair_from_list, order_expiry_setting_data, validity_midpoint_time) {
  let expiry_setting_tag =
    constr_tag_of(order_expiry_setting_data);
  or {
    1 =i= expiry_setting_tag,
    {
      let expiry_setting_fields =
        constr_fields_of(order_expiry_setting_data);
      (
        validity_midpoint_time
        <=
        (unIData(
          fstPair(
            {
              let expiry_value_pair_fields =
                list_first_list(expiry_setting_fields);
              data_pair_from_list(expiry_value_pair_fields)
            }
          )
        ))
      )
    },
  }
}

@captures 2;
fn assert_step_template(constr_tag_of, constr_fields_of, order_step_data) {
  let order_step_tag =
    constr_tag_of(order_step_data);
  !
    (
      if (0 =i= order_step_tag) {
        # {
          let order_step_fields =
            constr_fields_of(order_step_data);
          let swap_amount =
            list_first_int(order_step_fields);
          !
            (chooseList(tailList(order_step_fields), #(), #error))
        }
      } else {
        # {
          assert(1 =i= order_step_tag);
          !
            (chooseList(constr_fields_of(order_step_data), #(), #error))
        }
      }
    )
}

@captures 3;
fn assert_step_data_template(constr_tag_of, constr_fields_of, assert_tagged_single_byte_data, pool_step_data) {
  let pool_step_tag =
    constr_tag_of(pool_step_data);
  !
    (
      if (0 =i= pool_step_tag) {
        # {
          let pool_step_fields =
            constr_fields_of(pool_step_data);
          let tagged_step_data =
            list_first(pool_step_fields);
          !
            (chooseList(
              tailList(pool_step_fields),
              # {
                let tagged_step_checked =
                  assert_tagged_single_byte_data(tagged_step_data);
                ()
              },
              #error
            ))
        }
      } else {
        # {
          assert(1 =i= pool_step_tag);
          let pool_step_fields =
            constr_fields_of(pool_step_data);
          let [first_step_index << unIData, after_first_step_index] =
            pool_step_fields;
          let [second_step_index << unIData, after_second_step_index] =
            after_first_step_index;
          let third_step_index =
            list_first_int(after_second_step_index);
          !
            (chooseList(tailList(after_second_step_index), #(), #error))
        }
      }
    )
}

@captures 0;
fn check_each_list_item(list_items, item_checker) {
  zcom fn (check_items, remaining_items) {
    !
      (chooseList(
        remaining_items,
        #(),
        # {
          let item_checked =
            item_checker(list_first(remaining_items));
          check_items(check_items, tailList(remaining_items))
        }
      ))
  }(list_items)
}

