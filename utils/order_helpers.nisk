@captures 4;
fn assert_asset_data_template(constr_tag_of, constr_fields_of, assert_tagged_single_byte_data, assert_step_data, order_asset_data) {
  let order_asset_tag =
    constr_tag_of(order_asset_data);
  assert(0 =i= order_asset_tag);
  let order_asset_fields =
    constr_fields_of(order_asset_data);
  let [asset_data, after_asset_data] =
    order_asset_fields;
  let routing_step_option_data =
    list_first(after_asset_data);
  !
    (chooseList(
      tailList(after_asset_data),
      # {
        let asset_checked =
          assert_tagged_single_byte_data(asset_data);
        let routing_step_option_checked =
          {
            let routing_step_option_tag =
              constr_tag_of(routing_step_option_data);
            !
              (
                if (0 =i= routing_step_option_tag) {
                  # {
                    let routing_step_fields =
                      constr_fields_of(routing_step_option_data);
                    let routing_step_data =
                      list_first(routing_step_fields);
                    !
                      (chooseList(
                        tailList(routing_step_fields),
                        # {
                          let routing_step_checked =
                            assert_step_data(routing_step_data);
                          ()
                        },
                        #error
                      ))
                  }
                } else {
                  # {
                    assert(1 =i= routing_step_option_tag);
                    !
                      (chooseList(constr_fields_of(routing_step_option_data), #(), #error))
                  }
                }
              )
          };
        ()
      },
      #error
    ))
}

