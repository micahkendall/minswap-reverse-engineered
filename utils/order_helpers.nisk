branch "agent/minswap-reverse-engineer";
module_path "utils/order_helpers";

@captures 4;
fn assert_routing_list_template(constr_tag_of, constr_fields_of, list_first_constr_tag, validate_asset_pair, assert_swap_routing_list,
  remaining_routings) {
  !
    (chooseList(
      remaining_routings,
      #(),
      # {
        let routing_shape_checked =
          {
            let routing_data =
              list_first(remaining_routings);
            let routing_tag =
              constr_tag_of(routing_data);
            assert(
              (
                0
                =i=
                routing_tag
              )
            );
            let routing_fields =
              constr_fields_of(routing_data);
            let [routing_lp_asset_data, routing_after_lp_asset] =
              routing_fields;
            let routing_a_to_b =
              (
                1
                =i=
                list_first_constr_tag(routing_after_lp_asset)
              );
            !
              (chooseList(
                tailList(routing_after_lp_asset),
                # {
                  let routing_lp_asset_checked =
                    validate_asset_pair(routing_lp_asset_data);
                  ()
                },
                #error
              ))
          };
        assert_swap_routing_list(
          assert_swap_routing_list,
          tailList(remaining_routings)
        )
      }
    ))
}

@captures 4;
fn assert_stake_credential_shape(constr_tag_of, constr_fields_of, assert_tagged_single_byte_data, stake_credential_data) {
  let stake_credential_tag =
    constr_tag_of(stake_credential_data);
  !
    (
      if (0 =i= stake_credential_tag) {
        # {
          let stake_credential_fields =
            constr_fields_of(stake_credential_data);
          let stake_credential_hash_data =
            list_first(stake_credential_fields);
          !
            (chooseList(
              tailList(stake_credential_fields),
              # {
                let stake_credential_hash_checked =
                  assert_tagged_single_byte_data(stake_credential_hash_data);
                ()
              },
              #error
            ))
        }
      } else {
        # {
          assert(1 =i= stake_credential_tag);
          let stake_pointer_fields =
            constr_fields_of(stake_credential_data);
          let [stake_pointer_slot << unIData, stake_pointer_tail] =
            stake_pointer_fields;
          let [stake_pointer_tx_index << unIData, stake_pointer_after_tx_index] =
            stake_pointer_tail;
          let stake_pointer_cert_index =
            list_first_int(stake_pointer_after_tx_index);
          !
            (chooseList(
              tailList(stake_pointer_after_tx_index),
              #(),
              #error
            ))
        }
      }
    )
}

