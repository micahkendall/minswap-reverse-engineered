@captures 3;
fn assert_address_data_template(constr_tag_of, constr_fields_of, assert_tagged_single_byte_data, address_data) {
  let address_tag =
    constr_tag_of(address_data);
  assert(0 =i= address_tag);
  let address_fields =
    constr_fields_of(address_data);
  let [payment_credential_data, address_field_tail] =
    address_fields;
  let stake_credential_option_data =
    list_first(address_field_tail);
  !
    (chooseList(
      tailList(address_field_tail),
      # {
        let payment_credential_checked =
          assert_tagged_single_byte_data(payment_credential_data);
        let stake_credential_option_checked =
          assert_stake_credential_option_shape(
            constr_tag_of,
            constr_fields_of,
            assert_tagged_single_byte_data,
            stake_credential_option_data
          );
        ()
      },
      #error
    ))
}

@captures 2;
fn assert_empty_or_hashed_datum_choice_template(constr_tag_of, constr_fields_of, output_datum_data) {
  let output_datum_tag =
    constr_tag_of(output_datum_data);
