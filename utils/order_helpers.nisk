              if (1 =i= output_datum_tag) {
                # {
                  let output_datum_fields =
                    constr_fields_of(output_datum_data);
                  let output_datum_hash =
                    list_first_bytes(output_datum_fields);
                  !
                    (chooseList(tailList(output_datum_fields), #(), #error))
                }
              } else {
                # {
                  assert(2 =i= output_datum_tag);
                  let output_datum_fields =
                    constr_fields_of(output_datum_data);
                  let output_datum_hash =
                    list_first_bytes(output_datum_fields);
