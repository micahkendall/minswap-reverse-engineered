@captures 3;
fn find_reference_input_template(constr_fields_of, constr_tag_of, staking_credential_hash, find_reference_input, remaining_inputs) {
  !
    (chooseList(
      remaining_inputs,
      #data(constr 1 []),
      #
        {
          let [candidate_input, remaining_after_candidate] =
            remaining_inputs;
          !
            (
              if (
                {
                  let candidate_input_fields =
                    constr_fields_of(candidate_input);
                  let candidate_input_after_ref =
                    tailList(candidate_input_fields);
                  let candidate_resolved_output =
                    list_first(candidate_input_after_ref);
                  let candidate_output_fields =
                    constr_fields_of(candidate_resolved_output);
                  let candidate_address =
                    list_first(candidate_output_fields);
                  let candidate_address_fields =
                    constr_fields_of(candidate_address);
                  let candidate_spending_credential =
                    list_first(candidate_address_fields);
                  let candidate_credential_tag =
                    constr_tag_of(candidate_spending_credential);
                  and { 1 =i= candidate_credential_tag, list_first_bytes(constr_fields_of(candidate_spending_credential)) =b=
                    staking_credential_hash }
                }
              ) {
                #
                  (constrData(0, mkCons(candidate_input, list<data>[])))
              } else {
                #
                  (find_reference_input(find_reference_input, remaining_after_candidate))
              }
            )
        }
    ))
}

@captures 3;
fn validate_required_signer_list(tx_signatories, constr_fields_of, required_signer_datum, ignored_continuation) {
  let required_signers =
    list_first_list(constr_fields_of(required_signer_datum));
  fn all_required_signers_present(all_required_signers_present, remaining_required_signers) {
    !
      (chooseList(
        remaining_required_signers,
        #True,
        #
          {
            let [required_signer << unBData, remaining_required_signers_tail] =
              remaining_required_signers;
            and {
              {
                fn contains_signer(contains_signer, remaining_signers) {
                  !
                    (chooseList(
                      remaining_signers,
                      #False,
                      #
                        {
                          let [candidate_signer << unBData, remaining_signers_tail] =
                            remaining_signers;
                          or { candidate_signer =b= required_signer, contains_signer(contains_signer, remaining_signers_tail) }
                        }
                    ))
                }
                contains_signer(contains_signer, tx_signatories)
              },
              all_required_signers_present(all_required_signers_present, remaining_required_signers_tail),
            }
          }
      ))
  }
  all_required_signers_present(all_required_signers_present, required_signers)
}

@captures 1;
