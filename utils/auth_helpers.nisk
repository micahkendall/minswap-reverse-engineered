branch "agent/minswap-reverse-engineer";
module_path "utils/auth_helpers";

@captures 2;
fn assert_asset_class_template(constr_tag_of, constr_fields_of, asset_class_data) {
  let asset_class_tag =
    constr_tag_of(asset_class_data);
  assert(0 =i= asset_class_tag);
  let asset_class_fields =
    constr_fields_of(asset_class_data);
  let [policy_id << unBData, asset_tail] =
    asset_class_fields;
  let token_name =
    list_first_bytes(asset_tail);
  !
    (chooseList(tailList(asset_tail), #(), #error))
}

@captures 1;
fn flatten_assets_template(_capture, flatten_assets, remaining_policies) {
  !
    (chooseList(
      remaining_policies,
      #list<data>[],
      #
        {
          let policy_entry =
            list_first(remaining_policies);
          (
            fn (policy_id, token_entries, tail_assets) {
              zcom fn (prepend_token_entries, remaining_tokens) {
                !
                  (chooseList(
                    remaining_tokens,
                    #tail_assets,
                    #
                      {
                        let token_entry =
                          list_first(remaining_tokens);
                        mkCons(
                          listData(mkCons(
                            bData(policy_id),
                            mkCons(
                              bData(unBData(fstPair(token_entry))),
                              mkCons(
                                iData(unIData(sndPair(token_entry))),
                                list<data>[]
                              )
                            )
                          )),
                          prepend_token_entries(prepend_token_entries, tailList(remaining_tokens))
                        )
                      }
                  ))
              }(token_entries)
            }
            unBData(fstPair(policy_entry))
            unMapData(sndPair(policy_entry))
            (flatten_assets(flatten_assets, tailList(remaining_policies)))
          )
        }
    ))
}

@captures 2;
