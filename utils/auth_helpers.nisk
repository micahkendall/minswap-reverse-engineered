              #
                list_first_bytes(constr_fields_of(choice_data))
            } else {
              #
                !
                  (
                    if (1 =i= choice_tag) {
                      #
                        list_first_bytes(constr_fields_of(choice_data))
                    } else {
                      #
                        list_first_bytes(constr_fields_of(choice_data))
                    }
                  )
            }
          )
      }
    ))
    =i=
    28
  )
}

@captures 1;
fn all_have_policy_id_length_template(choice_has_policy_id_length, all_have_policy_id_length, remaining_choices) {
  !
