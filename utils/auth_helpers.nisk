@captures 2;
fn assert_choice_bytes_template(constr_tag_of, constr_fields_of, choice_data) {
  let choice_tag =
    constr_tag_of(choice_data);
  !
    (
      if (0 =i= choice_tag) {
        #
          {
            let choice_fields =
              constr_fields_of(choice_data);
            let choice_bytes =
              list_first_bytes(choice_fields);
            !
              (chooseList(tailList(choice_fields), #(), #error))
          }
      } else {
        #
          !
            (
              if (1 =i= choice_tag) {
                #
                  {
                    let choice_fields =
                      constr_fields_of(choice_data);
                    let choice_bytes =
                      list_first_bytes(choice_fields);
                    !
                      (chooseList(
                        tailList(choice_fields),
                        #(),
                        #error
                      ))
                  }
              } else {
                #
                  {
                    assert(2 =i= choice_tag);
                    let choice_fields =
                      constr_fields_of(choice_data);
                    let choice_bytes =
                      list_first_bytes(choice_fields);
                    !
                      (chooseList(
                        tailList(choice_fields),
                        #(),
                        #error
                      ))
                  }
              }
            )
      }
    )
}

@captures 3;
fn assert_redeemer_shape_template(constr_tag_of, constr_fields_of, assert_authen_choice_bytes_data, redeemer_data) {
  let redeemer_tag =
    constr_tag_of(redeemer_data);
  assert(0 =i= redeemer_tag);
  let redeemer_fields =
    constr_fields_of(redeemer_data);
  let [choice_list << unListData, choice_tail] =
    redeemer_fields;
  let [first_choice, second_tail] =
    choice_tail;
  let [second_choice, third_tail] =
    second_tail;
  let [third_choice, fourth_tail] =
    third_tail;
  let [fourth_choice, fifth_tail] =
    fourth_tail;
  let fifth_choice =
    list_first(fifth_tail);
  !
    (chooseList(
      tailList(fifth_tail),
      #
        {
          let list_choices_checked =
            {
              fn assert_choice_list(assert_choice_list, remaining_choices) {
                !
                  (chooseList(
                    remaining_choices,
                    #(),
                    #
                      {
                        let choice_checked =
                          assert_authen_choice_bytes_data(list_first(remaining_choices));
                        assert_choice_list(assert_choice_list, tailList(remaining_choices))
                      }
                  ))
              }
              assert_choice_list(assert_choice_list, choice_list)
            };
          let first_choice_checked =
            assert_authen_choice_bytes_data(first_choice);
          let second_choice_checked =
            assert_authen_choice_bytes_data(second_choice);
          let third_choice_checked =
            assert_authen_choice_bytes_data(third_choice);
          let fourth_choice_checked =
            assert_authen_choice_bytes_data(fourth_choice);
          let fifth_choice_checked =
            assert_authen_choice_bytes_data(fifth_choice);
          ()
        },
      #error
    ))
}

@captures 3;
fn filter_tagged_key_entries_template(constr_tag_of, constr_fields_of, selected_input_ref, filter_tagged_key_entries, remaining_entries) {
  !
    (chooseList(
      remaining_entries,
      #list<pair<data, data>>[],
      #
        {
          let [candidate_entry, remaining_entries_tail] =
            remaining_entries;
          !
            (
              if (
                {
                  let candidate_key =
                    fstPair(candidate_entry);
                  let candidate_key_tag =
                    constr_tag_of(candidate_key);
                  and {
                    1 =i= candidate_key_tag,
                    selected_input_ref =d= list_first(constr_fields_of(candidate_key)),
                  }
                }
              ) {
                #
                  (mkCons(
                    candidate_entry,
                    filter_tagged_key_entries(filter_tagged_key_entries, remaining_entries_tail)
                  ))
              } else {
                #
                  (filter_tagged_key_entries(filter_tagged_key_entries, remaining_entries_tail))
              }
            )
        }
    ))
}

@captures 3;
fn insert_policy_template(compare_token_names, selected_policy_id, msg_asset_map, insert_policy, remaining_policies) {
  !
    (chooseList(
      remaining_policies,
      #mkCons(mkPairData(bData(selected_policy_id), mapData(msg_asset_map)), list<pair<data, data>>[]),
      #
        {
          let [policy_entry, remaining_policies_tail] =
            remaining_policies;
          let policy_id =
            unBData(fstPair(policy_entry));
          let policy_assets =
            unMapData(sndPair(policy_entry));
          !
            (
              if (compare_token_names(selected_policy_id, policy_id) =d= data(constr 0 [])) {
                #
                  (mkCons(mkPairData(bData(selected_policy_id), mapData(msg_asset_map)), remaining_policies))
              } else {
                #
                  !
                    (
                      if (selected_policy_id =b= policy_id) {
                        #
                          (mkCons(
                            mkPairData(bData(selected_policy_id), mapData(msg_asset_map)),
                            remaining_policies_tail
                          ))
                      } else {
                        #
                          (mkCons(
                            mkPairData(bData(policy_id), mapData(policy_assets)),
                            insert_policy(insert_policy, remaining_policies_tail)
                          ))
                      }
                    )
              }
            )
        }
    ))
}

@captures 1;
fn insert_token_template(compare_token_names, insert_token, remaining_assets) {
  !
    (chooseList(
      remaining_assets,
      #mkCons(mkPairData(data(bytes 0x4d534753), data(1)), list<pair<data, data>>[]),
      #
        {
          let [asset_entry, remaining_assets_tail] =
            remaining_assets;
          let token_name =
            unBData(fstPair(asset_entry));
          let token_amount =
            unIData(sndPair(asset_entry));
          !
            (
              if (compare_token_names(0x4d534753, token_name) =d= data(constr 0 [])) {
                #
                  (mkCons(
                    mkPairData(data(bytes 0x4d534753), data(1)),
                    remaining_assets
                  ))
              } else {
                #
                  !
                    (
                      if (0x4d534753 =b= token_name) {
                        #
                          (mkCons(
                            mkPairData(data(bytes 0x4d534753), data(1)),
                            remaining_assets_tail
                          ))
                      } else {
                        #
                          (mkCons(
                            mkPairData(bData(token_name), iData(token_amount)),
                            insert_token(insert_token, remaining_assets_tail)
                          ))
                      }
                    )
              }
            )
        }
    ))
}

