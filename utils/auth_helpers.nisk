            list_first_bytes(remaining_signers);
          assert_all_bytes(assert_all_bytes, tailList(remaining_signers))
        }
    ))
}

@captures 1;
fn all_required_signers_present_template(tx_signatories, all_required_signers_present, remaining_required_signers) {
  !
    (chooseList(
      remaining_required_signers,
      #True,
      #
        {
          let [required_signer << unBData, remaining_after_required_signer] =
            remaining_required_signers;
          and {
            {
              fn contains_required_signer(contains_required_signer, remaining_signers) {
                !
                  (chooseList(
                    remaining_signers,
                    #False,
                    #
                      {
                        let [signer_hash << unBData, remaining_after_signer] =
                          remaining_signers;
                        or { signer_hash =b= required_signer, contains_required_signer(contains_required_signer, remaining_after_signer)
                          }
                      }
                  ))
              }
              contains_required_signer(contains_required_signer, tx_signatories)
            },
            all_required_signers_present(all_required_signers_present, remaining_after_required_signer),
          }
        }
    ))
}

