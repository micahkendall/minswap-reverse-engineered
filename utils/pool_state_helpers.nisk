@captures 3;
fn compute_validity_midpoint_time(constr_fields_of, constr_tag_of, tx_validity_range) {
  let validity_range_fields =
    constr_fields_of(tx_validity_range);
  let [lower_bound_data, after_lower_bound] =
    validity_range_fields;
  let upper_bound_data =
    list_first(after_lower_bound);
  let lower_bound_fields =
    constr_fields_of(lower_bound_data);
  let lower_bound_finite_data =
    list_first(lower_bound_fields);
  let upper_bound_fields =
    constr_fields_of(upper_bound_data);
  let upper_bound_finite_data =
    list_first(upper_bound_fields);
  assert(1 =i= constr_tag_of(lower_bound_finite_data));
  let lower_bound_finite_fields =
    constr_fields_of(lower_bound_finite_data);
  let lower_bound_time =
    list_first_int(lower_bound_finite_fields);
  assert(1 =i= constr_tag_of(upper_bound_finite_data));
  let upper_bound_finite_fields =
    constr_fields_of(upper_bound_finite_data);
  let upper_bound_time =
    list_first_int(upper_bound_finite_fields);
  assert(upper_bound_time - lower_bound_time <= 10 * 60 * 1000);
  (upper_bound_time - lower_bound_time) / 2 + lower_bound_time
}

