@captures 3;
fn apply_optional_fee_delta_template(constr_tag_of, constr_fields_of, int_between_inclusive, base_fee_bps, fee_delta_data, should_apply_delta) {
  let adjusted_fee_bps =
    !
      (
        if (should_apply_delta) {
          #
            {
              let fee_delta_tag =
                constr_tag_of(fee_delta_data);
              !
                (
                  if (1 =i= fee_delta_tag) {
                    #base_fee_bps
                  } else {
                    #
                      {
                        let fee_delta_fields =
                          constr_fields_of(fee_delta_data);
                        let fee_delta_bps =
                          list_first_int(fee_delta_fields);
                        assert(int_between_inclusive(fee_delta_bps, 200, 0));
                        fee_delta_bps + base_fee_bps
                      }
                  }
                )
            }
        } else {
          #base_fee_bps
        }
      );
  assert(int_between_inclusive(adjusted_fee_bps, 2000, 5));
  adjusted_fee_bps
}

