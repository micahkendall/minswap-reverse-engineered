@captures 6;
fn batching_authorizer_is_valid(
  constr_tag_of, constr_fields_of, selected_batcher_authorizer,
  tx_extra_signatories, tx_inputs, tx_withdrawals
) {
  let batcher_authorizer_tag =
    constr_tag_of(selected_batcher_authorizer);
  !
  (
    if (0 =i= batcher_authorizer_tag) {
      #
      (contains_byte_string_entry(tx_extra_signatories)(list_first_bytes(constr_fields_of(selected_batcher_authorizer))))
    } else {
      #
      !
      (
        if (1 =i= batcher_authorizer_tag) {
          #
          {
            let spend_script_authorizer_fields =
              constr_fields_of(selected_batcher_authorizer);
            let spend_script_hash =
              list_first_bytes(spend_script_authorizer_fields);
            contains_nested_data_entry(tx_inputs, constr_fields_of)(constrData(1, mkCons(bData(spend_script_hash), list<data>[])))
          }
        } else {
          #
          {
            let withdrawal_authorizer_key =
              constrData(
                0,
                mkCons(constrData(1, mkCons(list_first(constr_fields_of(selected_batcher_authorizer)), list<data>[])), list<data>[])
              );
            let withdrawal_map_contains_authorizer =
              withdrawal_map_contains_authorizer_template(withdrawal_authorizer_key);
            withdrawal_map_contains_authorizer(withdrawal_map_contains_authorizer, tx_withdrawals)
          }
        }
      )
    }
  )
}

