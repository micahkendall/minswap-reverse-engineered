      remaining_inputs,
      #data(constr 1 []),
      #
        {
          let [candidate_input, remaining_inputs_tail] =
            remaining_inputs;
          !
            (
              if (
                {
                  let input_fields =
                    constr_fields_of(candidate_input);
                  let input_tail =
                    tailList(input_fields);
                  let input_output =
                    list_first(input_tail);
                  let output_fields =
                    constr_fields_of(input_output);
                  let output_address =
                    list_first(output_fields);
                  let address_fields =
                    constr_fields_of(output_address);
                  let payment_credential =
                    list_first(address_fields);
                  let payment_credential_tag =
                    constr_tag_of(payment_credential);
                  and {
                    1 =i= payment_credential_tag,
                    list_first_bytes(constr_fields_of(payment_credential)) =b= pool_policy_id,
                  }
                }
              ) {
                #
                  (constrData(0, mkCons(candidate_input, list<data>[])))
              } else {
                #
                  (find_policy_input(find_policy_input, remaining_inputs_tail))
              }
            )
        }
    ))
}

