                  let remove_policy_entries_local =
                    drop_policy_entries;
                  and {
                    (
                    (mapData(remove_policy_entries_local(first_output_value, 0x)))
                    =d=
                      (mapData(
                    {
                      let compare_token_names =
                        compare_bytes_ordering;
                      !
                      (
                      if (1 =i= 0) {
                        #list<pair<data, data>>[]
                      } else {
                        #
                        {
                          let msg_asset_map =
                            {
                            let insert_token =
                              insert_token_template(compare_token_names);
                            insert_token(insert_token, list<pair<data, data>>[])
                          };
                          let insert_policy =
                            insert_policy_template(compare_token_names, selected_policy_id, msg_asset_map);
                          insert_policy(insert_policy, list<pair<data, data>>[])
                        }
                      }
                      )
                    }
                    ))
                    ),
                    first_output_payment_credential =d= selected_payment_credential,
                    mapData(remove_policy_entries_local(tx_mint_value, 0x)) =d= data({}),
                    {
                      let choice_has_policy_id_length =
                        choice_has_policy_id_length_template(constr_tag_of, constr_fields_of);
                      let redeemer_choice_fields =
                        constr_fields_of(first_output_datum_data);
                      let redeemer_choice_list =
                        list_first_list(redeemer_choice_fields);
                      let choice_tail =
                        tailList(redeemer_choice_fields);
                      let first_choice =
                        list_first(choice_tail);
                      let second_tail =
                        tailList(choice_tail);
                      let second_choice =
                        list_first(second_tail);
                      let third_tail =
                        tailList(second_tail);
                      let third_choice =
                        list_first(third_tail);
                      let fourth_tail =
                        tailList(third_tail);
                      let fourth_choice =
                        list_first(fourth_tail);
                      let fifth_tail =
                        tailList(fourth_tail);
                      let fifth_choice =
                        list_first(fifth_tail);
                      and {
                        choice_has_policy_id_length(first_choice),
                        choice_has_policy_id_length(second_choice),
                        choice_has_policy_id_length(third_choice),
                        choice_has_policy_id_length(fourth_choice),
                        choice_has_policy_id_length(fifth_choice),
                        if (nullList(redeemer_choice_list)) { False } else { True },
                        {
                          let all_have_policy_id_length =
                            all_have_policy_id_length_template(choice_has_policy_id_length);
                          all_have_policy_id_length(
                          all_have_policy_id_length,
                          redeemer_choice_list
                          )
                        },
                      }
                    },
                  }
                },
              }
            }
            ) {
              #()
            } else {
              #
              proc {
                !error;
                error
              }
            }
            )
          }
        }
      }
    )
  }
}
