                  let liquidity_product = amount_a * amount_b;
                  let sqrt_floor =
                    !
                  (
                  liquidity_product < 0
                  ? #error
                  : #!
                  (
                  liquidity_product =i= 0
                  ? #0
                  : #!
                  (
                  liquidity_product =i= 1
                  ? #1
                  : #!
                  (
                  liquidity_product =i= 2
                  ? #1
                  : #
                  {
                    let sqrt_seed = liquidity_product / 2 + 1;
                    let sqrt_iter =
                      integer_sqrt_iter(liquidity_product);
                    sqrt_iter(sqrt_iter, liquidity_product, sqrt_seed)
                  }
                  )
                  )
                  )
                  );
                  !(sqrt_floor * sqrt_floor < liquidity_product ? #(sqrt_floor + 1) : #sqrt_floor)
