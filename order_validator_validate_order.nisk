                            unIData(sndPair(expiry_pair_fields))
                          };
                          ()
                        },
                        #error
                        ))
                      }
                    } else {
                      #
                      {
                        assert(1 =i= expiry_setting_tag);
                        !
                        (chooseList(constr_fields_of(expiry_setting_option_data), #(), #error))
                      }
                    }
                    )
                  };
                  ()
                },
                #error
                ))
              };
              let order_datum_fields =
                constr_fields_of(order_datum);
              let canceller_data =
                list_first(order_datum_fields);
              let canceller_tag =
                constr_tag_of(canceller_data);
              !
              (
              if (0 =i= canceller_tag) {
                #
                (contains_byte_string_entry(tx_signatories)(list_first_bytes(constr_fields_of(canceller_data))))
              } else {
                #
                !
                (
                if (1 =i= canceller_tag) {
                  #
                  {
                    let spend_script_fields =
                      constr_fields_of(canceller_data);
                    let spend_script_hash =
                      list_first_bytes(spend_script_fields);
                    contains_nested_data_entry(tx_inputs, constr_fields_of)(
                    constrData(1, mkCons(bData(spend_script_hash), list<data>[]))
                    )
                  }
                } else {
                  #
                  !
                  (
                  if (2 =i= canceller_tag) {
                    #
                    (map_contains_data_key(
                    tx_withdrawals,
                    constrData(0, mkCons(constrData(1, mkCons(list_first(constr_fields_of(canceller_data)), list<data>[])),
                    list<data>[]))
                    ))
                  } else {
                    #
                    (
                    if (
                    (
                    (unIData(
                    sndPair(
                    list_first(
                    (
                    fn (value_map, target_policy_id) {
                      let policy_assets_option =
                        {
                        let find_policy_assets =
                          find_policy_entry_template(target_policy_id);
                        find_policy_assets(find_policy_assets, value_map)
                      };
                      let policy_assets_option_tag =
                        constr_tag_of(policy_assets_option);
                      !
                      (
                      if (1 =i= policy_assets_option_tag) {
                        #list<pair<data, data>>[]
                      } else {
                        #
                        list_first_map(constr_fields_of(policy_assets_option))
                      }
                      )
                    }
                    {
                      let remove_ada_policy_entries =
                        remove_ada_entries_template(());
                      remove_ada_policy_entries(remove_ada_policy_entries, tx_mint_value)
                    }
                    list_first_bytes(constr_fields_of(canceller_data))
                    )
                    )
                    )
                    ))
                    =i=
                      0
                    )
                    ) {
                      False
                    } else {
                      True
                    }
                    )
                  }
                  )
                }
                )
              }
              )
            }
          } else {
            #
            (map_contains_data_key(
            tx_info_withdrawals_map(constr_fields_of, tx_info_data),
            expired_order_cancel_credential
            ))
          }
          )
        }
        )
      }
      ) {
        #()
      } else {
        #
        proc {
          !error;
          error
        }
      }
    )
  }
}
